rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- USER PROFILES ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string && data.email.size() <= 200 &&
               data.role in ['student', 'business', 'mentor', 'admin'] &&
               (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100));
      }
      
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; // Secure list
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'avatarUrl', 'skills', 'updatedAt'])
      );
    }

    // --- ORGANIZATIONS ---
    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerUid == request.auth.uid;
      allow update: if isSignedIn() && existing().ownerUid == request.auth.uid;
    }

    // --- OPPORTUNITIES ---
    match /opportunities/{oppId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Add more strict creator checks in production
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn();
    }

    // --- PROJECTS (Research Hub) ---
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in existing().teamMembers || existing().creatorUid == request.auth.uid);
    }

    // --- VERIFICATIONS ---
    match /verifications/{requestId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
    }

    // --- CHATS & MESSAGES ---
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().senderUid == request.auth.uid;
    }
  }
}
